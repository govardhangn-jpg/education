PORT=5000
MONGODB_URI=mongodb://localhost:27017/samarthaa
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
ANTHROPIC_API_KEY=your_anthropic_api_key_here
NODE_ENV=development

# Allow requests from the React dev server
# React starts on 3000 by default, or 5001 if 3000 is taken
CLIENT_URL=http://localhost:3000

# ── ElevenLabs Text-to-Speech (optional but recommended) ──────────────────────
# Get your API key at: https://elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Voice ID for English (default: "Sarah" — warm, clear, works for Indian English)
# Browse voices at: https://elevenlabs.io/voice-library
# Recommended Indian-English voices: 
#   Sarah          → EXAVITQu4vr4xnSDxMaL  (warm female)
#   Aria           → 9BWtsMINqrJLrRacOk9x  (friendly female)
#   Charlie        → IKne3meq5aSn9XLyUdCD  (friendly male)
#   George         → JBFqnCBsd6RMkjVDRZzb  (authoritative male)
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# Optional: separate voice IDs per language (falls back to ELEVENLABS_VOICE_ID)
# ELEVENLABS_VOICE_ID_KANNADA=your_voice_id
# ELEVENLABS_VOICE_ID_HINDI=your_voice_id
# ELEVENLABS_VOICE_ID_TELUGU=your_voice_id
# ELEVENLABS_VOICE_ID_TAMIL=your_voice_id
